#!/usr/bin/env sh
# Block any AI attribution in commit messages
if git log -1 --format="%B" 2>/dev/null | grep -qi "co-authored-by\|claude\|openai\|generated with\|generated by ai"; then
  echo "✗ Commit blocked: remove AI attribution from commit message"
  exit 1
fi

# Bump patch version in package.json and stage it
node -e "
const fs = require('fs');
const pkg = JSON.parse(fs.readFileSync('package.json', 'utf8'));
const parts = pkg.version.split('.').map(Number);
parts[2]++;
pkg.version = parts.join('.');
fs.writeFileSync('package.json', JSON.stringify(pkg, null, 2) + '\n');
console.log('Version bumped to ' + pkg.version);
"
git add package.json

npx lint-staged
